---
// Testimonials.astro  S12: 5 คลิป testimonial + รูป review (IBtes)
const clips = [
  {
    src: "https://res.cloudinary.com/dzjum15hd/video/upload/v1775835560/bank-uncensored/Clip%20-%20Vox%20pop%20%E0%B8%A3%E0%B8%A7%E0%B8%A1%20_%E0%B8%82%E0%B8%B2%E0%B8%A2%20Bank%20online_.mp4",
    quote: "ถ้าธุรกิจมีปัญหาเรื่องการเงิน อยากให้ลองมาเจอพี่วิน",
  },
  {
    src: "https://res.cloudinary.com/dzjum15hd/video/upload/v1775835566/bank-uncensored/Clip%20-%20%E0%B8%84%E0%B8%B8%E0%B8%93%E0%B8%99%E0%B8%B4%E0%B8%A7_%E0%B8%82%E0%B8%B2%E0%B8%A2%20Bank%20online_.mp4",
    quote: "รู้เขา รู้เรา...เช็คความพร้อมก่อนกู้ กับคลาส Bank Uncensored",
  },
  {
    src: "https://res.cloudinary.com/dzjum15hd/video/upload/v1775835570/bank-uncensored/Clip%20-%20%E0%B8%84%E0%B8%B8%E0%B8%93%E0%B8%A0%E0%B8%B1%E0%B8%AA%E0%B8%AA%E0%B8%A3_%E0%B8%82%E0%B8%B2%E0%B8%A2%20Bank%20online_.mp4",
    quote: "รู้วิธีการกู้หลักร้อยล้านยังไงให้ผ่าน เคล็ดลับที่ไม่ได้มีบอกทั่วไป",
  },
  {
    src: "https://res.cloudinary.com/dzjum15hd/video/upload/v1775835574/bank-uncensored/Clip%20-%20%E0%B8%84%E0%B8%B8%E0%B8%93%E0%B8%AB%E0%B8%A1%E0%B8%ADAi_%E0%B8%82%E0%B8%B2%E0%B8%A2%20Bank%20online_.mp4",
    quote: "SME ที่หาทางไปไม่เจอ ควรมาเรียนคลาสนี้",
  },
  {
    src: "https://res.cloudinary.com/dzjum15hd/video/upload/v1775835578/bank-uncensored/Clip%20-%20%E0%B8%84%E0%B8%B8%E0%B8%93%E0%B8%AD%E0%B8%B2%E0%B8%A0%E0%B8%B2%E0%B8%A3%E0%B8%B1%E0%B8%95%E0%B8%99%E0%B9%8C_%E0%B8%82%E0%B8%B2%E0%B8%A2%20Bank%20online_.mp4",
    quote: "เปลี่ยนมุมมองเรื่องการกู้เงินทำธุรกิจ จากความกลัวสู่ความมั่นใจ เติบโตได้ทันที",
  },
];
---

<section class="w-full bg-black py-16 md:py-24 border-t border-zinc-900">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold text-white leading-tight mb-3">
        เสียงจากเจ้าของธุรกิจที่เคยเรียนกับวิน
      </h2>
      <p class="text-gray-300 text-lg md:text-xl max-w-2xl mx-auto">
        ไม่มีเคล็ดลับลัด ไม่มีเส้นสาย แค่<span class="text-yellow-400 font-medium">เข้าใจว่าธนาคารหาอะไร</span> แล้วเตรียมตัวให้ตรงจุด
      </p>
    </div>

    <!-- 5 คลิป ขนาดเท่ากันหมด -->
    <!-- แถวที่ 1: 3 คลิป -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 md:gap-5 mb-4 md:mb-5">
      {clips.slice(0, 3).map((clip) => (
        <div class="bg-zinc-900 border border-zinc-800 rounded-2xl overflow-hidden group hover:border-yellow-400/30 transition-colors">
          <div class="relative w-full aspect-[9/16] bg-black">
            <video class="w-full h-full object-contain" controls preload="metadata" playsinline>
              <source src={clip.src} type="video/mp4" />
            </video>
          </div>
          <div class="p-3 md:p-4">
            <p class="text-gray-200 text-sm md:text-base leading-relaxed italic">"{clip.quote}"</p>
          </div>
        </div>
      ))}
    </div>
    <!-- แถวที่ 2: 2 คลิป กลาง -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 md:gap-5 mb-10 max-w-2xl mx-auto">
      {clips.slice(3).map((clip) => (
        <div class="bg-zinc-900 border border-zinc-800 rounded-2xl overflow-hidden group hover:border-yellow-400/30 transition-colors">
          <div class="relative w-full aspect-[9/16] bg-black">
            <video class="w-full h-full object-contain" controls preload="metadata" playsinline>
              <source src={clip.src} type="video/mp4" />
            </video>
          </div>
          <div class="p-3 md:p-4">
            <p class="text-gray-200 text-sm md:text-base leading-relaxed italic">"{clip.quote}"</p>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
