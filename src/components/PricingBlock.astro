---
// PricingBlock.astro — Pricing 4 ขั้น + Cost comparison + Urgency + CTA (จุดที่ 2)
const { id } = Astro.props;
---

<section id={id} class="w-full bg-[#0a0a0a] py-16 md:py-24 border-t border-yellow-500/10">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold text-white leading-tight mb-3">
        ราคาสำหรับคนที่พร้อมเตรียมตัวก่อนคนอื่น
      </h2>
      <p class="text-gray-400 text-lg">ยิ่งตัดสินใจเร็ว ยิ่งได้ราคาพิเศษกว่า</p>
    </div>

    <!-- Pricing Cards -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 mb-14">

      <!-- Insider -->
      <div class="bg-zinc-900 border-2 border-yellow-500/50 rounded-2xl p-6 text-center relative shadow-[0_0_30px_-10px_rgba(250,204,21,0.3)] lg:col-span-2">
        <div class="absolute -top-4 inset-x-0 flex justify-center">
          <span class="bg-yellow-500 text-black font-bold py-1.5 px-6 rounded-full text-sm tracking-wide uppercase shadow-[0_4px_10px_rgba(234,179,8,0.4)]">
            ★ Insider Price — 30 คนแรกเท่านั้น ★
          </span>
        </div>
        <div class="mt-6 bg-black/60 rounded-xl p-5 border border-zinc-800">
          <p class="text-gray-400 mb-1">30 คนแรกที่ติดตาม</p>
          <p class="text-5xl font-black text-yellow-400 tracking-tight">4,900</p>
          <p class="text-gray-400 text-base mt-1">บาท</p>
          <p class="text-gray-600 text-sm line-through mt-2">ราคาเต็ม 15,900 บาท</p>
        </div>
        <a href="https://page.line.me/591xftzn?openQrModal=true" target="_blank" rel="noopener noreferrer"
           class="mt-5 block w-full py-3.5 bg-yellow-500 hover:bg-yellow-400 text-black font-bold rounded-xl transition-all hover:scale-105">
          สมัครราคา Insider
        </a>
      </div>

      <!-- Early Bird -->
      <div class="bg-zinc-900 border border-zinc-700 rounded-2xl p-6 text-center relative">
        <div class="absolute -top-4 inset-x-0 flex justify-center">
          <span class="bg-zinc-700 text-white font-bold py-1.5 px-4 rounded-full text-sm tracking-wide uppercase">
            Early Bird
          </span>
        </div>
        <div class="mt-6 bg-black/60 rounded-xl p-5 border border-zinc-800">
          <p class="text-gray-400 text-sm mb-1">1-30 เม.ย. 2569</p>
          <p class="text-4xl font-black text-white tracking-tight">5,900</p>
          <p class="text-gray-400 text-sm mt-1">บาท</p>
        </div>
        <a href="https://page.line.me/591xftzn?openQrModal=true" target="_blank" rel="noopener noreferrer"
           class="mt-5 block w-full py-3 bg-zinc-700 hover:bg-zinc-600 text-white font-bold rounded-xl transition-all text-sm">
          สมัคร Early Bird
        </a>
      </div>

      <!-- ราคาปกติ -->
      <div class="bg-zinc-900 border border-zinc-800 rounded-2xl p-6 text-center opacity-70 relative">
        <div class="absolute -top-4 inset-x-0 flex justify-center">
          <span class="bg-zinc-800 text-gray-400 font-bold py-1.5 px-4 rounded-full text-sm tracking-wide uppercase">
            ราคาปกติ
          </span>
        </div>
        <div class="mt-6 bg-black/60 rounded-xl p-5 border border-zinc-800">
          <p class="text-gray-500 text-sm mb-1">หลังโปรโมชั่น</p>
          <p class="text-4xl font-black text-gray-400 tracking-tight">7,900</p>
          <p class="text-gray-500 text-sm mt-1">บาท</p>
        </div>
        <div class="mt-5 block w-full py-3 bg-zinc-800 text-gray-500 font-bold rounded-xl text-sm cursor-default">
          ราคาปกติ
        </div>
      </div>

    </div>

    <!-- Promotion Urgency -->
    <div class="bg-red-900/10 border border-red-500/20 rounded-2xl p-5 md:p-6 text-center mb-12">
      <p class="text-white font-bold text-lg">⚡ PROMOTION: 1-30 เมษายน เท่านั้น</p>
      <p class="text-gray-300 text-base mt-1">หมดโปรแล้วราคาขึ้นทันที — ไม่มีข้อยกเว้น</p>
    </div>

    <!-- Cost Comparison -->
    <div class="max-w-3xl mx-auto mb-14">
      <h3 class="text-xl md:text-2xl font-bold text-white mb-6 text-center">เปรียบเทียบต้นทุน</h3>
      <div class="rounded-2xl overflow-hidden border border-zinc-800">
        <div class="grid grid-cols-2 bg-zinc-900">
          <div class="p-4 border-b border-zinc-800">
            <p class="text-gray-400 font-medium text-sm">รายการ</p>
          </div>
          <div class="p-4 border-b border-l border-zinc-800">
            <p class="text-gray-400 font-medium text-sm">ค่าใช้จ่าย</p>
          </div>
        </div>
        <div class="grid grid-cols-2 bg-zinc-900/50">
          <div class="p-4 border-b border-zinc-800">
            <p class="text-white text-sm font-medium">คอร์ส Bank Uncensored Online (Insider Price)</p>
          </div>
          <div class="p-4 border-b border-l border-zinc-800">
            <p class="text-yellow-400 font-bold text-sm">4,900 บาท</p>
          </div>
        </div>
        <div class="grid grid-cols-2 bg-zinc-900/30">
          <div class="p-4 border-b border-zinc-800">
            <p class="text-gray-300 text-sm">ค่าเสียหายจากการกู้ไม่ผ่านสักรอบ</p>
          </div>
          <div class="p-4 border-b border-l border-zinc-800">
            <p class="text-red-400 font-medium text-sm">หลักแสน – ล้านบาท</p>
          </div>
        </div>
        <div class="grid grid-cols-2 bg-zinc-900/50">
          <div class="p-4 border-b border-zinc-800">
            <p class="text-gray-300 text-sm">ค่าดอกเบี้ยที่จ่ายแพงกว่าจำเป็น เพราะไม่รู้ว่าต้องเตรียมอะไร</p>
          </div>
          <div class="p-4 border-b border-l border-zinc-800">
            <p class="text-red-400 font-medium text-sm">หลักหมื่น – แสน/ปี</p>
          </div>
        </div>
        <div class="grid grid-cols-2 bg-zinc-900/30">
          <div class="p-4">
            <p class="text-gray-300 text-sm">เวลาที่เสียไปจากการยื่นแล้วโดนปฏิเสธ</p>
          </div>
          <div class="p-4 border-l border-zinc-800">
            <p class="text-red-400 font-medium text-sm">3-6 เดือน ที่ได้คืนไม่ได้</p>
          </div>
        </div>
      </div>
      <div class="mt-6 border-l-4 border-yellow-500 pl-6 py-2">
        <p class="text-xl md:text-2xl font-bold text-yellow-400 leading-snug">
          คุณจะลงทุน 4 ชั่วโมง เพื่อเช็คตัวเองก่อน<br class="hidden sm:block" />
          หรือจะเสียอีกปีเพื่อรู้ทีหลัง?
        </p>
      </div>
    </div>

  </div>
</section>
