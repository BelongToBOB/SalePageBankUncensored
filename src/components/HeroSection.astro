---
// HeroSection.astro  Main KV + Headline + Subheadline
---

<section class="w-full bg-black py-8 md:py-12 mt-1 md:mt-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Main KV  อยู่บนสุด เป็นสิ่งแรกที่คนเห็น -->
    <!-- ปรับความกว้าง (บีบ margin) ให้รูปไม่ใหญ่จนเกินไปบนจอคอม และลบ md:min-h ออกเพื่อให้กรอบพอดีกับรูป 100% -->
    <div class="relative w-full max-w-5xl mx-auto group overflow-hidden rounded-2xl md:rounded-3xl shadow-[0_20px_50px_-12px_rgba(250,204,21,0.15)] border border-yellow-400/20 bg-zinc-900/40 flex items-center justify-center">
      <!-- Background Ambient Glow -->
      <div
      class="relative w-full md:h-[80vh] overflow-hidden rounded-2xl md:rounded-3xl shadow-[0_20px_50px_-12px_rgba(250,204,21,0.15)] border border-yellow-400/20"
    >
      <img
        src="/asset/images/mainkvbuc2.webp"
        alt="Exclusive Private Consult Key Visual"
        class="w-full h-full object-cover object-center margin-2"
        loading="eager"
      />
    </div>
    </div>

    <!-- Headline + Subheadline -->
    <div class="max-w-3xl mx-auto text-center mt-10 px-6">
      <p class="text-yellow-400 text-sm font-semibold uppercase tracking-widest mb-3">Bank Uncensored Online</p>
      <h1 class="text-2xl md:text-4xl font-bold text-white leading-tight mb-6">
        ก่อนจะถามว่า "กู้ผ่านไหม"<br class="hidden sm:block" />
        คุณควรรู้ก่อนว่า ธุรกิจคุณ<br class="hidden sm:block" />
        คือ <span class="text-yellow-400">"โอกาส"</span> หรือ <span class="text-red-400">"ความเสี่ยง"</span><br class="hidden sm:block" />
        ในสายตาธนาคาร
      </h1>
      <p class="text-gray-300 text-lg leading-relaxed mb-3">
        คลาสออนไลน์ 4 ชั่วโมง สอนโดยอดีต RM ธนาคารกสิกร 7 ปี<br class="hidden md:block" />
        ที่ปัจจุบันเป็นเจ้าของธุรกิจ ใช้สินเชื่อธนาคาร ลงทุนเป็นร้อยล้าน
      </p>

      <p class="text-gray-400 text-base">
        เรียนจบ คุณจะ<span class="text-yellow-400 font-medium">เช็คตัวเองได้ทันที</span> ว่าพร้อมกู้แค่ไหน และต้องแก้อะไรก่อนเดินเข้าธนาคาร
      </p>
    </div>

    <!-- S2: รูปวิน  Mobile: auto-scroll slider / Desktop: grid 3 cols -->
    <!-- Desktop: grid -->
    <div class="max-w-5xl mx-auto mt-10 hidden sm:grid grid-cols-3 gap-4">
      <div class="relative w-full aspect-[4/3] rounded-2xl overflow-hidden bg-zinc-900 border border-yellow-400/20 group">
        <img src="/asset/images/win-ptt-team.webp" alt="วินกับทีมงานที่ปั๊ม PTT" class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />
        <div class="absolute inset-0 border border-yellow-400/20 group-hover:border-yellow-400/50 rounded-2xl transition-colors pointer-events-none"></div>
      </div>
      <div class="relative w-full aspect-[4/3] rounded-2xl overflow-hidden bg-zinc-900 border border-yellow-400/20 group">
        <img src="/asset/images/win-cafe-amazon.webp" alt="วินกับธุรกิจ Cafe Amazon" class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />
        <div class="absolute inset-0 border border-yellow-400/20 group-hover:border-yellow-400/50 rounded-2xl transition-colors pointer-events-none"></div>
      </div>
      <div class="relative w-full aspect-[4/3] rounded-2xl overflow-hidden bg-zinc-900 border border-yellow-400/20 group">
        <img src="/asset/images/win-7eleven.webp" alt="วินในร้าน 7-Eleven" class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />
        <div class="absolute inset-0 border border-yellow-400/20 group-hover:border-yellow-400/50 rounded-2xl transition-colors pointer-events-none"></div>
      </div>
    </div>

    <!-- Mobile: auto-scroll slider -->
    <div class="sm:hidden mt-8 relative overflow-hidden">
      <div id="hero-slider" class="flex gap-3 overflow-x-auto snap-x snap-mandatory scroll-smooth px-4 pb-4 -mx-4" style="scrollbar-width:none;-webkit-overflow-scrolling:touch;">
        <div class="relative shrink-0 w-[80vw] aspect-[4/3] rounded-xl overflow-hidden bg-zinc-900 border border-yellow-400/20">
          <img src="/asset/images/win-ptt-team.webp" alt="วินกับทีมงานที่ปั๊ม PTT" class="absolute inset-0 w-full h-full object-cover snap-center" loading="lazy" />
          <div class="absolute inset-0 border border-yellow-400/20 rounded-xl pointer-events-none"></div>
        </div>
        <div class="relative shrink-0 w-[80vw] aspect-[4/3] rounded-xl overflow-hidden bg-zinc-900 border border-yellow-400/20">
          <img src="/asset/images/win-cafe-amazon.webp" alt="วินกับธุรกิจ Cafe Amazon" class="absolute inset-0 w-full h-full object-cover snap-center" loading="lazy" />
          <div class="absolute inset-0 border border-yellow-400/20 rounded-xl pointer-events-none"></div>
        </div>
        <div class="relative shrink-0 w-[80vw] aspect-[4/3] rounded-xl overflow-hidden bg-zinc-900 border border-yellow-400/20">
          <img src="/asset/images/win-7eleven.webp" alt="วินในร้าน 7-Eleven" class="absolute inset-0 w-full h-full object-cover snap-center" loading="lazy" />
          <div class="absolute inset-0 border border-yellow-400/20 rounded-xl pointer-events-none"></div>
        </div>
      </div>
      <!-- Dots indicator -->
      <div class="flex justify-center gap-2 mt-3" id="hero-dots">
        <span class="w-2 h-2 rounded-full bg-yellow-400 transition-colors"></span>
        <span class="w-2 h-2 rounded-full bg-zinc-600 transition-colors"></span>
        <span class="w-2 h-2 rounded-full bg-zinc-600 transition-colors"></span>
      </div>
    </div>

    <script>
      const slider = document.getElementById('hero-slider');
      const dots = document.querySelectorAll('#hero-dots span');
      if (slider && dots.length) {
        // Auto-scroll
        let current = 0;
        const total = 3;
        const auto = setInterval(() => {
          current = (current + 1) % total;
          const child = slider.children[current] as HTMLElement;
          slider.scrollTo({ left: child.offsetLeft - 16, behavior: 'smooth' });
        }, 3000);

        // Update dots on scroll
        slider.addEventListener('scroll', () => {
          const scrollLeft = slider.scrollLeft;
          const width = (slider.children[0] as HTMLElement).offsetWidth + 12;
          const index = Math.round(scrollLeft / width);
          dots.forEach((d, i) => {
            d.classList.toggle('bg-yellow-400', i === index);
            d.classList.toggle('bg-zinc-600', i !== index);
          });
          current = index;
        });

        // Pause on touch
        slider.addEventListener('touchstart', () => clearInterval(auto), { passive: true });
      }
    </script>

  </div>
</section>
