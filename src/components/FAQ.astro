---
// FAQ.astro — S18: 11 ข้อ accordion (native details/summary)
const faqs = [
  {
    q: "ถ้าเข้าวันสด 20 พ.ค. ไม่ได้ ทำยังไง?",
    a: "ไม่ต้องห่วงค่ะ — ทุกคนที่สมัครจะได้วิดีโอบันทึกการสอนเต็ม หลังคลาสจบ ดูย้อนหลังได้ตลอด รวมถึง Recap Q&A วันที่ 25 มิถุนายน 2569 ก็มีบันทึกให้ดูเช่นกัน",
  },
  {
    q: "สมัครวันนี้ ระหว่างรอวันที่ 20 พ.ค. จะได้อะไรก่อนไหม?",
    a: "ได้ค่ะ — หลังสมัครและยืนยันการชำระเงิน คุณจะได้รับ Ebook \"คู่มืออ่านงบการเงินฉบับเจ้าของธุรกิจ\" + Template Excel คำนวณวงเงินกู้ทันที เพื่อให้คุณเริ่มทำความเข้าใจเบื้องต้นก่อนเข้าคลาสสด",
  },
  {
    q: "คอร์สนี้ต่างจากคลาสสด Bank Uncensored 27,900 ยังไง?",
    a: "คลาสออนไลน์นี้คือ \"เช็คก่อนกู้\" — สอนให้คุณรู้ว่าธุรกิจตัวเองพร้อมแค่ไหน อยู่ตรงไหนในสายตาธนาคาร และต้องแก้อะไรก่อน ส่วนคลาสสด 27,900 คือ \"วางโครงสร้างก่อนและหลังการกู้\" — วินวิเคราะห์งบการเงินของธุรกิจคุณเอง (ไม่ใช่เคสตัวอย่าง) + ที่ปรึกษาส่วนตัวหลังคลาส",
  },
  {
    q: "ฉันไม่มีพื้นฐานบัญชี เรียนเข้าใจไหม?",
    a: "เข้าใจค่ะ — คลาสนี้ออกแบบมาสำหรับ \"เจ้าของธุรกิจ\" ไม่ใช่นักบัญชี วินจะสอนให้อ่านงบในมุมเจ้าของ โฟกัสเฉพาะตัวเลขที่ธนาคารดู ไม่ต้องรู้ทุกบรรทัด",
  },
  {
    q: "เหมาะกับธุรกิจขนาดไหน?",
    a: "คลาสนี้ออกแบบมาสำหรับเจ้าของธุรกิจที่มียอดขาย 10–70 ล้านบาท/ปี เป็นกลุ่มหลัก ถ้ายอดขายต่ำกว่า 10 ล้าน/ปี เรียนได้ (จะได้เริ่มต้นถูก) ถ้ายอดขายเกิน 70 ล้าน/ปี แนะนำ InsideBank Workshop (27,900) หรือ Private Consult",
  },
  {
    q: "ถ้าฉันยังไม่เคยกู้เลย เรียนได้ไหม?",
    a: "ได้ค่ะ — คลาสนี้เหมาะมากสำหรับคนที่ \"กำลังจะกู้ครั้งแรก\" เพราะจะทำให้คุณเตรียมตัวถูกตั้งแต่แรก ไม่เสียเวลาลองผิดลองถูก",
  },
  {
    q: "Insider Community เข้าได้นานแค่ไหน?",
    a: "เข้าได้ตลอดชีพค่ะ — ตราบใดที่ InsideBank ยังเปิดดำเนินการ คุณจะยังคงเป็นสมาชิกของกลุ่มนี้ และยังได้รับอัปเดตข้อมูลธนาคารต่อเนื่อง",
  },
  {
    q: "ใช้ใบเสร็จลดหย่อนภาษีได้ไหม?",
    a: "ออกใบเสร็จในนามบริษัทได้ค่ะ สามารถนำไปลงค่าใช้จ่ายในงบของบริษัทได้ตามปกติ",
  },
  {
    q: "ชำระเงินยังไง?",
    a: "โอนผ่านบัญชีธนาคาร / สแกน QR Code / หรือชำระผ่านบัตรเครดิต (ไม่มีค่าธรรมเนียม) หลังโอนแล้วส่งสลิปในไลน์ @WIN_WIN จะมีแอดมินยืนยันการสมัครภายใน 24 ชั่วโมง",
  },
  {
    q: "คลาสนี้รับประกันว่าเรียนแล้วกู้ผ่านไหม?",
    a: "ไม่ค่ะ — และวินไม่เคยรับประกันแบบนั้น เพราะการอนุมัติสินเชื่อขึ้นอยู่กับสถานะของแต่ละธุรกิจ และเงื่อนไขของแต่ละธนาคาร ไม่มีใครรับประกันได้จริง แต่สิ่งที่คลาสนี้รับประกันได้คือ — คุณจะเข้าใจมุมมองของธนาคาร และรู้ว่าตัวเองอยู่ตรงไหน ก่อนเสียเวลาไปยื่นจริง",
  },
  {
    q: "ติดเครดิตบูโรเรียนได้ไหม? จะกู้ผ่านไหม?",
    a: "เรียนได้แน่นอนค่ะ แต่ \"กู้ผ่าน\" ต้องดูเป็นเคสๆ ไป คลาสนี้แยก 4 Case ของการติดบูโรให้คุณเห็น — ปิดแล้ว / ยังค้าง / NPL / ถูกฟ้อง — แต่ละ Case แก้ไม่เหมือนกัน พร้อม 4 ทางที่ยังมีโอกาสกู้ได้",
  },
];
---

<section class="w-full bg-black py-16 md:py-24 border-t border-zinc-900">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-3">คำถามที่พบบ่อย</h2>
      <p class="text-gray-400">ถ้ายังมีคำถาม แอดไลน์ @WIN_WIN ได้เลยค่ะ</p>
    </div>

    <div class="space-y-3">
      {faqs.map((faq, i) => (
        <details class="group bg-zinc-900 border border-zinc-800 rounded-xl overflow-hidden">
          <summary class="flex items-center justify-between gap-4 px-5 py-4 cursor-pointer list-none select-none">
            <span class="text-white font-medium text-base leading-snug">
              <span class="text-yellow-400/70 text-sm font-bold mr-2">Q{i + 1}</span>
              {faq.q}
            </span>
            <span class="text-yellow-400 shrink-0 transition-transform duration-200 group-open:rotate-45 text-xl font-light">+</span>
          </summary>
          <div class="px-5 pb-5 pt-1">
            <p class="text-gray-400 text-base leading-relaxed border-t border-zinc-800 pt-4">{faq.a}</p>
          </div>
        </details>
      ))}
    </div>

  </div>
</section>
