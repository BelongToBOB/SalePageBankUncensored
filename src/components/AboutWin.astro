---
// AboutWin.astro — ทำไมต้องเรียนกับวิน — สั้น 2 ด้าน
---

<section class="w-full bg-black py-16 md:py-24 border-t border-zinc-900">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="text-center mb-10">
      <h2 class="text-3xl md:text-4xl font-bold text-white leading-tight mb-3">
        ทำไมต้องเรียนกับวิน?
      </h2>
      <p class="text-gray-400 text-lg">วินกลั่นกรองคลาสนี้จากประสบการณ์จริง 2 ด้าน</p>
    </div>

    <div class="flex items-start sm:items-center space-x-4 sm:space-x-6 bg-zinc-900/80 border border-zinc-800 rounded-2xl p-6 md:p-8 mb-6">
      <div class="w-full">
        <h4 class="text-lg md:text-xl font-bold text-white leading-tight mb-5">
          พบกับ คุณวิน กวินทร์รัศม์ นิธิกรภาคย์
        </h4>

        <div class="space-y-5">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-xl bg-yellow-500/10 border border-yellow-500/30 flex items-center justify-center shrink-0">
              <span class="text-yellow-400 font-bold text-sm">1</span>
            </div>
            <div>
              <p class="text-white font-semibold mb-1">อดีต RM ธนาคารกสิกร 7 ปี</p>
              <p class="text-sm md:text-base text-gray-400 leading-relaxed">
                เห็นเคสอนุมัติและปฏิเสธเป็นร้อยเคส รู้ว่าธนาคารดูอะไร คิดอะไร ตัดสินจากอะไรจริงๆ — ไม่ใช่สิ่งที่เขียนไว้ในเว็บบน Google
              </p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-xl bg-yellow-500/10 border border-yellow-500/30 flex items-center justify-center shrink-0">
              <span class="text-yellow-400 font-bold text-sm">2</span>
            </div>
            <div>
              <p class="text-white font-semibold mb-1">เจ้าของธุรกิจที่ลงทุนเป็นร้อยล้าน ด้วยเงินกู้ธนาคาร</p>
              <p class="text-sm md:text-base text-gray-400 leading-relaxed">
                ผ่านกระบวนการกู้มาเองจริง รู้ทั้งมุมคนให้กู้ และมุมคนกู้ เข้าใจความรู้สึกของเจ้าของธุรกิจ — เพราะวินคือหนึ่งในนั้น
              </p>
            </div>
          </div>
        </div>

        <!-- Closing quote -->
        <div class="mt-6 border-l-4 border-yellow-500 pl-5 py-2">
          <p class="text-yellow-400 font-bold text-base md:text-lg leading-snug">
            "วินคือคนเดียวที่อยู่ทั้ง 2 ด้าน — และนั่นคือเหตุผลที่คลาสนี้จะไม่เหมือนคลาสไหนที่คุณเคยเรียน"
          </p>
        </div>
      </div>
    </div>

    <!-- ภาพวินสอนออนไลน์ 6 ภาพ -->
    <div class="grid grid-cols-2 md:grid-cols-3 gap-3 md:gap-4 mb-6">
      {[2, 1, 3, 6, 5, 4].map((n) => (
        <div class="relative w-full aspect-square rounded-xl md:rounded-2xl overflow-hidden bg-zinc-900 border border-zinc-800 group shadow-[0_0_20px_-8px_rgba(250,204,21,0.1)]">
          <img
            src={`/asset/images/win-teaching-${n}.jpg`}
            alt={`วินสอนออนไลน์ Bank Uncensored ${n}`}
            class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
            loading="lazy"
          />
          <div class="absolute inset-0 border border-yellow-400/20 group-hover:border-yellow-400/50 rounded-xl md:rounded-2xl transition-colors pointer-events-none"></div>
        </div>
      ))}
    </div>

  </div>
</section>
