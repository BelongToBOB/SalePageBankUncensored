---
// TransformationTable.astro  ก่อน vs หลัง 9 แถว (จาก FINAL SECTION 10)
const rows = [
  {
    before: '"กู้ได้ไหม?"',
    after: '"ฉันอยู่ตรงไหน  ต้องทำอะไรต่อ"',
  },
  {
    before: '"ธนาคารมองเรายังไงไม่รู้"',
    after: '"รู้ว่าธนาคารเช็คอะไรใน Trust Box 3 กล่อง"',
  },
  {
    before: '"อ่านงบไม่ออก"',
    after: '"โฟกัสจุดที่ธนาคารดู อ่านใน 5 นาที"',
  },
  {
    before: '"ไม่รู้กู้ได้เท่าไหร่"',
    after: '"คำนวณวงเงินเบื้องต้นเองได้"',
  },
  {
    before: '"Statement คืออะไร ทำไมธนาคารต้องดู"',
    after: '"รู้ว่า Statement บอกอะไร เตรียมให้ถูกได้"',
  },
  {
    before: '"ติดบูโร = จบชีวิต กู้ไม่ได้แน่"',
    after: '"รู้ว่าตัวเองเป็น Case ไหน + มีทางไหนบ้างที่ยังกู้ได้"',
  },
  {
    before: '"เตรียมเอกสารครบแล้ว น่าจะผ่าน"',
    after: '"รู้ว่าเอกสารเป็นแค่ 1 ใน 3 กล่อง"',
  },
  {
    before: '"กลัวเดินเข้าธนาคาร"',
    after: '"มั่นใจในสิ่งที่เตรียม"',
  },
  {
    before: '"รอคำตอบ"',
    after: '"รู้คำตอบของตัวเองก่อนส่งเอกสาร"',
  },
];
---

<section class="w-full bg-[#0a0a0a] py-16 md:py-24 border-t border-yellow-500/10">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold text-white leading-tight mb-3">
        ก่อนเรียน vs หลังเรียน
      </h2>
    </div>

    <!-- Desktop Table -->
    <div class="hidden md:block rounded-2xl overflow-hidden border border-zinc-800">
      <div class="grid grid-cols-2">
        <div class="bg-red-900/20 border-b border-zinc-800 p-4 text-center">
          <span class="text-red-400 font-bold text-lg">😥 ก่อนเรียน</span>
        </div>
        <div class="bg-green-900/10 border-b border-l border-zinc-800 p-4 text-center">
          <span class="text-green-400 font-bold text-lg">🎯 หลังเรียน</span>
        </div>
        {rows.map((row, i) => (
          <>
            <div class={`bg-zinc-900/50 p-4 md:p-5 ${i < rows.length - 1 ? 'border-b border-zinc-800' : ''}`}>
              <p class="text-gray-400 text-base">{row.before}</p>
            </div>
            <div class={`bg-zinc-900/30 p-4 md:p-5 border-l border-zinc-800 ${i < rows.length - 1 ? 'border-b border-zinc-800' : ''}`}>
              <p class="text-white font-medium text-base">{row.after}</p>
            </div>
          </>
        ))}
      </div>
    </div>

    <!-- Mobile Cards -->
    <div class="md:hidden space-y-4">
      {rows.map((row) => (
        <div class="bg-zinc-900 border border-zinc-800 rounded-xl overflow-hidden">
          <div class="bg-red-900/20 px-4 py-3 border-b border-zinc-800">
            <p class="text-gray-400 text-sm"><span class="text-red-400 mr-1">😥</span>{row.before}</p>
          </div>
          <div class="px-4 py-3">
            <p class="text-white font-medium text-sm"><span class="text-green-400 mr-1">🎯</span>{row.after}</p>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
